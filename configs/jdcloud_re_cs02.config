# Web + LuCI全套强制开启
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_uhttpd-mod-lua=y
CONFIG_PACKAGE_uhttpd-mod-cgi=y
CONFIG_PACKAGE_liblua=y
CONFIG_PACKAGE_luci-cgi=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-firewall=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-status=y

# 平台设备锁定
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y

# 编译冲突修复
CONFIG_PACKAGE_odhcpd-ipv6only=n
CONFIG_PACKAGE_libselinux=n
CONFIG_PACKAGE_libpcre2=n
CONFIG_PACKAGE_policycoreutils=n

# 基础系统
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_libc=y
CONFIG_PACKAGE_libgcc=y
CONFIG_PACKAGE_libpthread=y
CONFIG_PACKAGE_librt=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_sysupgrade=y

# DHCP/DNS
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_odhcpd=y
CONFIG_PACKAGE_odhcp6c=y

# PPPoE
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

# 防火墙
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-nat=y

# DSA/PHY网口驱动
CONFIG_PHYLIB=y
CONFIG_PHY_AT803X=y
CONFIG_PACKAGE_kmod-phylink=y
CONFIG_PACKAGE_kmod-dsa=y
CONFIG_PACKAGE_kmod-dsa-qca8k=y
CONFIG_PACKAGE_swconfig=y

# NSS加速
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-drv-bridge-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-vlan-mgr=y
CONFIG_PACKAGE_kmod-qca-ssdk=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y

# 虚拟网口
CONFIG_PACKAGE_kmod-macvlan=y

# 禁用无线
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_ipq-wifi-jdcloud_re-cs-02=n

# 网络工具
CONFIG_PACKAGE_ip-tiny=y
CONFIG_PACKAGE_kmod-inet-diag=y

# 镜像打包必备
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_procd-ubus=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_ubox=y
CONFIG_PACKAGE_switchdev=y
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fstools=y
CONFIG_PACKAGE_squashfs-tools-mtd=y
CONFIG_PACKAGE_ubi-utils=y

# 编译优化
CONFIG_BUILD_LOG=y
CONFIG_CCACHE=y
# CONFIG_DEVEL=n

# 禁用USB
# CONFIG_PACKAGE_kmod-usb3=y
# CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
# CONFIG_PACKAGE_ip-full=y
# CONFIG_PACKAGE_kmod-netlink-diag=y
